{
	"name": "rootprint",
	"version": "0.3.6",
	"description": "Open-source, self-hosted log management platform with full-text search directly on object storage.",
	"type": "module",
	"private": true,
	"license": "Apache-2.0",
	"author": "Oleksandr Zhyhalo",
	"repository": {
		"type": "git",
		"url": "https://github.com/rootprint/rootprint.git"
	},
	"homepage": "https://rootprint.io",
	"keywords": [
		"logging",
		"log-management",
		"object-storage",
		"quickwit",
		"log-viewer",
		"observability"
	],
	"engines": {
		"bun": ">=1.0.0"
	},
	"workspaces": [
		"apps/*"
	],
	"scripts": {
		"prepare": "git config core.hooksPath .githooks",
		"dev:api": "bun --filter api dev",
		"dev:web": "bun --filter web dev",
		"build:api": "bun --filter api build",
		"start:api": "bun --filter api start",
		"check": "bun --filter '*' check",
		"lint": "bun --filter '*' lint",
		"openapi:generate": "bun --filter api openapi:generate",
		"format": "prettier --write .",
		"format:check": "prettier --check ."
	},
	"lint-staged": {
		"*.{ts,js,svelte,json,css,md}": "prettier --write"
	},
	"devDependencies": {
		"@types/node": "^26.1.1",
		"lint-staged": "^17.1.1",
		"oxlint": "^1.75.0",
		"prettier": "^3.9.6",
		"prettier-plugin-svelte": "^4.1.1",
		"prettier-plugin-tailwindcss": "^0.8.1",
		"typescript": "^6.0.3"
	},
	"overrides": {
		"vite": "^7.3.3"
	},
	"packageManager": "bun@1.3.11"
}
