{
	"$schema": "https://mintlify.com/docs.json",
	"theme": "luma",
	"name": "Logwiz",
	"colors": {
		"primary": "#848c8e",
		"light": "#11161e",
		"dark": "#cfd0d2"
	},
	"favicon": "/favicon.ico",
	"logo": {
		"light": "/images/logo.png",
		"dark": "/images/logo.png"
	},
	"navbar": {
		"primary": {
			"type": "github",
			"href": "https://github.com/oleksandr-zhyhalo/logwiz"
		}
	},
	"redirects": [
		{
			"source": "/send-logs/http-ingest",
			"destination": "/send-logs/http"
		},
		{
			"source": "/send-logs",
			"destination": "/send-logs/overview"
		}
	],
	"navigation": {
		"tabs": [
			{
				"tab": "Documentation",
				"groups": [
					{
						"group": "Get Started",
						"pages": [
							"index",
							{
								"group": "Installation",
								"pages": ["install/docker-compose", "install/scaling"]
							},
							"quickstart",
							"indexes"
						]
					},
					{
						"group": "Send Logs",
						"pages": [
							"send-logs/overview",
							"send-logs/otlp",
							{
								"group": "Languages",
								"pages": [
									"send-logs/languages/python",
									"send-logs/languages/javascript",
									"send-logs/languages/go",
									"send-logs/languages/java",
									"send-logs/languages/dotnet"
								]
							},
							{
								"group": "Platforms",
								"pages": ["send-logs/platforms/docker"]
							},
							{
								"group": "Log Agents",
								"pages": ["send-logs/log-agents/fluent-bit", "send-logs/log-agents/vector"]
							},
							{
								"group": "Other",
								"pages": ["send-logs/http"]
							}
						]
					},
					{
						"group": "Search",
						"pages": ["search/query-language"]
					},
					{
						"group": "Configuration",
						"pages": [
							"configuration/environment-variables",
							"configuration/google-auth",
							"configuration/reset-admin-password",
							"configuration/index-config",
							"configuration/custom-indexes",
							"configuration/manage-indexes"
						]
					}
				]
			}
		]
	}
}
