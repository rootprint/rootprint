# Server
HOST=0.0.0.0
PORT=8282

# Database (PostgreSQL)
DATABASE_URL=postgres://logwiz:logwiz@localhost:5432/logwiz

# Quickwit
QUICKWIT_URL=http://localhost:7280

# Better Auth
BETTER_AUTH_SECRET=your-secret-here
BETTER_AUTH_URL=http://localhost:8282
FRONTEND_URL=http://localhost:5173

# Google OAuth: configured via the admin settings UI (writes to the app_settings table).
# Setting GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET as env vars has no effect.

# Single-container mode: serve the SvelteKit static build from Hono.
# Set by the Docker image; leave unset in local dev.
# LOGWIZ_SERVE_WEB=true
# LOGWIZ_WEB_ROOT=./web
