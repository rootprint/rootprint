# Required ---------------------------------------------------------------

# PostgreSQL connection string.
DATABASE_URL=postgres://rootprint:rootprint@localhost:5432/rootprint

# Canonical public URL of this Rootprint instance. Used for Better Auth
# callbacks, invite links, CORS allow-list, and cookies.
# Local dev: http://localhost:5173 (Vite dev server with proxy).
# Production: your public HTTPS URL, e.g. https://logs.example.com.
ORIGIN=http://localhost:5173

# Quickwit REST endpoint.
QUICKWIT_URL=http://localhost:7280

# Optional ---------------------------------------------------------------

# Override the auto-generated Better Auth signing secret. If unset, Rootprint
# generates one on first boot and stores it in app_settings. If set, must
# be at least 32 characters. Generate with: openssl rand -hex 32
# BETTER_AUTH_SECRET=

# Additional allowed CORS origin (for split SPA + API deployments where
# the SPA is hosted on a different origin from the API).
# FRONTEND_URL=

# Override the HTTP listen port. Default 8282.
# PORT=8282

# Number of trusted reverse proxies / load balancers in front of Rootprint
# that set X-Forwarded-For. Rate limits then key on the client IP read at that
# depth (e.g. 1 = a single nginx/Caddy in front; 2 = CDN + load balancer).
# Leave 0 (default) for direct exposure, where the TCP peer IP is used. Setting
# this higher than your real proxy count lets clients spoof XFF and forge keys.
# TRUST_PROXY_HOPS=0

# Rate limiting (in-memory, per-process). Window is shared by both limiters.
# PUBLIC_AUTH_RATE_LIMIT: requests per IP per window on unauthenticated auth
# routes. READ_RATE_LIMIT: requests per actor per window on search/histogram/
# field-values/share-resolve. Defaults shown.
# RATE_LIMIT_WINDOW_MS=60000
# PUBLIC_AUTH_RATE_LIMIT=30
# READ_RATE_LIMIT=300

# Google OAuth: configured via the admin settings UI (writes to the
# app_settings table). Setting GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET
# as env vars has no effect.
