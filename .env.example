# Required ---------------------------------------------------------------

# PostgreSQL connection string.
DATABASE_URL=postgres://logwiz:logwiz@localhost:5432/logwiz

# Canonical public URL of this Logwiz instance. Used for Better Auth
# callbacks, invite links, CORS allow-list, and cookies.
# Local dev: http://localhost:5173 (Vite dev server with proxy).
# Production: your public HTTPS URL, e.g. https://logs.example.com.
ORIGIN=http://localhost:5173

# Quickwit REST endpoint.
QUICKWIT_URL=http://localhost:7280

# Optional ---------------------------------------------------------------

# Override the auto-generated Better Auth signing secret. If unset, Logwiz
# generates one on first boot and stores it in app_settings. If set, must
# be at least 32 characters. Generate with: openssl rand -hex 32
# BETTER_AUTH_SECRET=

# Additional allowed CORS origin (for split SPA + API deployments where
# the SPA is hosted on a different origin from the API).
# FRONTEND_URL=

# Override the HTTP listen port. Default 8282.
# PORT=8282

# Google OAuth: configured via the admin settings UI (writes to the
# app_settings table). Setting GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET
# as env vars has no effect.
