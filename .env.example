# Required — app will not start without these
LOGWIZ_QUICKWIT_URL="http://localhost:7280/api/v1"
# Optional canonical URL override (auto-detected from request URL when unset)
# Set when behind a reverse proxy: ORIGIN="https://logs.example.com"

# Optional — defaults shown
# LOGWIZ_DATABASE_PATH="./data/logwiz.db"
# LOGWIZ_ADMIN_EMAIL="logwiz@logwiz.local"
# LOGWIZ_ADMIN_USERNAME="logwiz"
# LOGWIZ_ADMIN_PASSWORD="logwiz"
# LOGWIZ_INVITE_EXPIRY_HOURS=48
# LOGWIZ_RATE_LIMIT_WINDOW=60
# LOGWIZ_RATE_LIMIT_MAX=100
# LOGWIZ_SIGNIN_RATE_LIMIT_MAX=5
# LOGWIZ_AUTH_SECRET="replace-with-32+-chars"
