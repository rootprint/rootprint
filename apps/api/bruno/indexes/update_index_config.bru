meta {
  name: Update Index Config
  type: http
  seq: 4
}

patch {
  url: {{baseUrl}}/api/indexes/{{indexId}}/config
  body: json
  auth: none
}

body:json {
  {
    "displayName": "Application Logs",
    "visibility": "all",
    "levelField": "severity_text",
    "messageField": "body.message",
    "tracebackField": "attributes.exception.stacktrace",
    "contextFields": ["service.name", "host.name"]
  }
}
