{
  "name": "api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./types": {
      "types": "./src/types.ts",
      "default": "./src/types.ts"
    },
    "./schemas": {
      "types": "./src/schemas/index.ts",
      "default": "./src/schemas/index.ts"
    }
  },
  "scripts": {
    "dev": "bun --hot src/app.ts",
    "build": "bun build src/app.ts --target=bun --outdir=dist",
    "check": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint",
    "start": "bun run dist/app.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "proto:gen": "buf generate"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.12.0",
    "better-auth": "^1.6.10",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.0",
    "nanoid": "^5.1.11",
    "pg": "^8.20.0",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "quickwit-js": "^0.3.7",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@bufbuild/buf": "^1.69.0",
    "@bufbuild/protoc-gen-es": "^2.12.0",
    "@types/pg": "^8.20.0",
    "bun-types": "^1.1.0",
    "drizzle-kit": "^0.31.10"
  }
}
