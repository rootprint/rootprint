{
	"name": "api",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		},
		"./types": {
			"types": "./src/types.ts",
			"default": "./src/types.ts"
		},
		"./schemas": {
			"types": "./src/schemas/index.ts",
			"default": "./src/schemas/index.ts"
		},
		"./constants": {
			"types": "./src/constants.ts",
			"default": "./src/constants.ts"
		},
		"./query": {
			"types": "./src/lib/query/compose-query.ts",
			"default": "./src/lib/query/compose-query.ts"
		}
	},
	"scripts": {
		"dev": "bun --hot src/app.ts",
		"build": "bun build src/app.ts --target=bun --outdir=dist",
		"check": "tsc -p tsconfig.json --noEmit",
		"lint": "oxlint",
		"start": "bun run dist/app.js",
		"openapi:generate": "bun scripts/generate-openapi.ts",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"proto:gen": "buf generate"
	},
	"dependencies": {
		"@better-auth/api-key": "^1.6.23",
		"@bufbuild/protobuf": "^2.12.1",
		"@hono/standard-validator": "^0.2.3",
		"@valibot/to-json-schema": "^1.7.1",
		"better-auth": "^1.6.23",
		"dotenv": "^17.4.2",
		"drizzle-orm": "^0.45.2",
		"hono": "^4.12.27",
		"hono-openapi": "^1.3.0",
		"hono-rate-limiter": "^0.5.3",
		"pg": "^8.22.0",
		"quickwit-js": "^0.3.7",
		"valibot": "^1.4.2"
	},
	"devDependencies": {
		"@bufbuild/buf": "^1.71.0",
		"@standard-schema/spec": "^1.1.0",
		"@bufbuild/protoc-gen-es": "^2.12.1",
		"@types/pg": "^8.20.0",
		"bun-types": "^1.1.0",
		"drizzle-kit": "^0.31.10"
	}
}
